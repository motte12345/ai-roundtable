# LLM プロバイダ API キー（無料枠で運用、CC不要、電話番号認証も不要）

# Google AI Studio (Gemini 2.5 Flash + Flash-Lite)
# Optimist と Host で使用（1キーで両モデル使える）
# https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Groq (Llama 3.3 70B + Llama 3.1 8B Instant)
# Skeptic 主、各キャラの fallback で使用（1キーで両モデル使える）
# https://console.groq.com/keys
GROQ_API_KEY=

# Cerebras (Llama 3.3 70B)
# Zen 主、Skeptic の fallback で使用
# https://cloud.cerebras.ai/
CEREBRAS_API_KEY=

# Mistral Experiment tier (mistral-small-latest)
# 議論ハイライト生成に使用（Groq の TPD を圧迫しないため）
# 2 RPM / 月1B tokens、電話番号認証必要、API リクエストが学習に利用される
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Cloudflare Turnstile（議題候補への投票で bot/spam 防止）
# Cloudflare Dashboard → Turnstile → Add site で発行
# - Site key (公開、フロント埋め込み): VITE_TURNSTILE_SITE_KEY
# - Secret key (Worker サーバーサイド検証用): TURNSTILE_SECRET_KEY
#   → wrangler secret put TURNSTILE_SECRET_KEY で本番設定
VITE_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Cloudflare REST API（backfill-audio スクリプト用）
# Workers AI と R2 を Worker 外（ローカル Node）から叩くために必要
# - Account ID: https://dash.cloudflare.com 右下に表示
# - API Token: My Profile → API Tokens → Create Custom Token
#   必要な権限: Account → Workers AI:Edit, R2 Storage:Edit, D1:Edit
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=

# LINE 通知（Cron 失敗時に管理者に通知）
# line-notify プロジェクトと同じチャネルを共用（既存 Token をそのまま貼り付け）
# 未設定でも動作する（その場合は通知スキップ）
LINE_CHANNEL_TOKEN=
LINE_USER_ID=
